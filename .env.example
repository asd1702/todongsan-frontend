VITE_API_BASE_URL=http://localhost:9000

VITE_APP_NAME=Todongsan Frontend

# Mock API mode
# false: use real API Gateway
# true: use MSW/mock handlers if mock mode is implemented
VITE_USE_MOCKS=false

# Local development helper values
# In normal Gateway mode, the frontend must NOT send X-Member-Id or X-Member-Role.
# These values are reserved only for isolated local tests when directly calling a backend service.
VITE_DEV_MEMBER_ID=
VITE_DEV_MEMBER_ROLE=

# OAuth callback path
# The actual Kakao authorization URL is provided by the backend/member-point service.
VITE_KAKAO_CALLBACK_PATH=/auth/kakao/callback
